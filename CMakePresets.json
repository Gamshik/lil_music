{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "msvc-x64-debug",
      "displayName": "MSVC x64 Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/msvc-x64-debug",
      "toolchainFile": "${sourceDir}/cmake/toolchains/msvc_ninja_toolchain.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SOUNDCLOUD_TARGET_ARCH": "x64"
      }
    },
    {
      "name": "msvc-x64-release",
      "displayName": "MSVC x64 Release",
      "inherits": "msvc-x64-debug",
      "binaryDir": "${sourceDir}/build/msvc-x64-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "msvc-x64-debug",
      "configurePreset": "msvc-x64-debug"
    },
    {
      "name": "msvc-x64-release",
      "configurePreset": "msvc-x64-release"
    }
  ]
}
